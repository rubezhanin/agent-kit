# ============================================================================
# Hermes Agent Architecture Kit — environment template
# ============================================================================
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env`, real secrets, or session files to the repository.
# ============================================================================

# ----------------------------------------------------------------------------
# Kit installer behaviour
# ----------------------------------------------------------------------------

# Comma-separated list of profiles to enable by default.
# Leave empty to fall back to the values declared in kit-manifest.json.
HERMES_KIT_DEFAULT_PROFILES=

# Run installer in dry-run mode (no writes, no install commands).
HERMES_KIT_DRY_RUN=false

# Auto-confirm non-destructive prompts (still asks before external side-effects).
HERMES_KIT_YES=false

# Absolute path to the target workspace. If empty, the installer uses
# the bundled `agent-center/` directory in place.
HERMES_KIT_WORKSPACE=

# Absolute path to an existing Hermes home directory (e.g. ~/.hermes).
# When set, the installer writes a `hermes-kit` package pointer into
# `<HERMES_HOME>/profiles/<main-profile>/hermes-kit/`.
HERMES_KIT_HERMES_HOME=

# Name of the main Hermes profile to bootstrap. Defaults to `main-operator`.
HERMES_KIT_MAIN_PROFILE=main-operator

# Also include profiles that are disabled by default (e.g. telegram-channel-watcher).
HERMES_KIT_INCLUDE_DISABLED=false

# ----------------------------------------------------------------------------
# Hermes install command
# ----------------------------------------------------------------------------

# If Hermes CLI is not found on PATH, the installer may run this command
# after explicit confirmation. Leave empty if you prefer to install Hermes
# yourself before running the kit installer.
HERMES_KIT_HERMES_INSTALL_COMMAND=

# Set to `true` to allow the installer to run the install command without
# an interactive prompt. The installer still prints the command first.
HERMES_KIT_INSTALL_HERMES=false

# ----------------------------------------------------------------------------
# Telegram channel intelligence (optional, disabled by default)
# ----------------------------------------------------------------------------

# Master switch for the Telegram channel intelligence skill.
HERMES_TELEGRAM_ENABLED=false

# Watcher runtime: `tdlib` (preferred, production), `telethon` (prototype),
# `bot_api` (only for owned/admin channels), or `manual` (human-driven).
HERMES_TELEGRAM_RUNTIME=manual

# Comma-separated list of explicitly approved Telegram channel handles.
# Examples: "@channel_one,@channel_two". Discovery (search) is allowed
# without listing handles; joining/subscribing is forbidden without
# an entry here AND explicit owner approval.
HERMES_TELEGRAM_APPROVED_CHANNELS=

# Path to the watcher session file. MUST NOT be inside the repository.
HERMES_TELEGRAM_SESSION_PATH=

# Phone number for the dedicated watcher account (international format, +...).
HERMES_TELEGRAM_PHONE=

# Telegram API credentials from https://my.telegram.org/apps.
HERMES_TELEGRAM_API_ID=
HERMES_TELEGRAM_API_HASH=

# Optional Bot API token, only used for owned/admin channels.
HERMES_TELEGRAM_BOT_TOKEN=

# ----------------------------------------------------------------------------
# Reporting and logs
# ----------------------------------------------------------------------------

# Where installer receipts are written. Relative paths are resolved against
# the workspace. The default value matches the kit's expected layout.
HERMES_KIT_RECEIPT_DIR=reports/task-receipts

# Default language for the main profile output (BCP-47 / ISO-639-1 code).
# Examples: en, ru, de.
HERMES_KIT_DEFAULT_LANGUAGE=en

# Default IANA timezone for the main profile (e.g. Europe/Moscow, UTC).
HERMES_KIT_TIMEZONE=UTC

# ----------------------------------------------------------------------------
# Safety overrides — keep these at the defaults unless you really know why
# ----------------------------------------------------------------------------

# Allowed values: strict, balanced, permissive.
HERMES_KIT_SAFETY_LEVEL=strict

# When `true`, the installer never edits existing files outside the workspace.
HERMES_KIT_LOCK_OUTSIDE_WORKSPACE=true

# When `true`, the installer refuses to run any shell command sourced from
# environment variables (defence in depth against poisoned .env files).
HERMES_KIT_REFUSE_SHELL_FROM_ENV=true